# pgserve reads DATABASE_URL for its admin pool — keep it free of ?host= / ?socket= params.
DATABASE_URL="postgresql://postgres@localhost:8432/redwoodgql"
# Prisma connects via unix socket (pgserve TCP requires password auth).
PRISMA_DATABASE_URL="postgresql://postgres@localhost:8432/redwoodgql?host=/run/user/UID/pgserve&socket=/run/user/UID/pgserve"
PRISMA_HIDE_UPDATE_MESSAGE=true
