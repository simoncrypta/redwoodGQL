{
  "name": "rwsdk",
  "version": "1.0.0",
  "private": true,
  "description": "A RedwoodSDK app managed by Vite+",
  "keywords": [],
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "vp run @rwsdk/apollo#build && vp run @rwsdk/cell#build && vp build",
    "dev": "vp run @rwsdk/apollo#build && vp run @rwsdk/cell#build && vp dev",
    "dev:init": "rw-scripts dev-init",
    "preview": "vp preview",
    "worker:run": "rw-scripts worker-run",
    "clean": "vp run clean:vite",
    "clean:vite": "rm -rf ./node_modules/.vite",
    "release": "rw-scripts ensure-deploy-env && vp run clean && vp run build && wrangler deploy",
    "generate": "rw-scripts ensure-env && wrangler types --include-runtime false",
    "check": "vp run @rwsdk/apollo#build && vp run @rwsdk/cell#build && vp run generate && vp run types",
    "types": "tsc"
  },
  "dependencies": {
    "@apollo/client": "^4.2.3",
    "@apollo/client-react-streaming": "0.14.5",
    "@rwsdk/apollo": "workspace:*",
    "@rwsdk/cell": "workspace:*",
    "graphql": "^17.0.1",
    "humanize-string": "2.1.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.66.0",
    "react-hot-toast": "^2.6.0",
    "react-server-dom-webpack": "19.2.6",
    "rwsdk": "file:/home/simoncrypta/rwsdk/sdk",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.33.2",
    "@cloudflare/workers-types": "4.20260426.1",
    "@types/node": "~25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "wrangler": "4.85.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
